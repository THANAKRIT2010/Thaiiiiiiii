    local SelectedSitPlayer = nil
    local SitType = "Head"
    local AlignPos, AlignOri, MyAttachment, TargetAttachment
    local function StopSit() if AlignPos then AlignPos:Destroy() AlignPos = nil end if AlignOri then AlignOri:Destroy() AlignOri = nil end if MyAttachment then MyAttachment:Destroy() MyAttachment = nil end if TargetAttachment then TargetAttachment:Destroy() TargetAttachment = nil end end
    local function StartSit()
        StopSit()
        if not (SelectedSitPlayer and SelectedSitPlayer.Character and LocalPlayer.Character) then return end
        local targetHRP = SelectedSitPlayer.Character:FindFirstChild("HumanoidRootPart")
        local myHRP = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        local myHum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if not (targetHRP and myHRP and myHum) then return end
        myHum.Sit = true
        myHum:ChangeState(Enum.HumanoidStateType.Seated)
        MyAttachment = Instance.new("Attachment", myHRP)
        TargetAttachment = Instance.new("Attachment", targetHRP)
        if SitType == "Head" then TargetAttachment.Position = Vector3.new(0, 2.5, 0) elseif SitType == "Back" then TargetAttachment.Position = Vector3.new(0, 0.5, -1.2) TargetAttachment.Orientation = Vector3.new(0, 180, 0) end
        AlignPos = Instance.new("AlignPosition", myHRP) AlignPos.Attachment0, AlignPos.Attachment1 = MyAttachment, TargetAttachment AlignPos.RigidityEnabled = true
