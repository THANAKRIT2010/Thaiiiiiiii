local InvisibleEnabled = false
local OriginalTransparencies = {}

PlayerTab:AddToggle("InvisTog", {
    Title = "โหมดล่องหน (Invisible)",
    Description = "ทำให้ตัวละครหายไป/กลับมามองเห็น",
    Default = false,
    Callback = function(Value)
        InvisibleEnabled = Value
        local char = LocalPlayer.Character
        if not char then return end

        if InvisibleEnabled then
            -- เก็บค่าความโปร่งใสเดิมและทำให้ล่องหน
            for _, v in pairs(char:GetDescendants()) do
                if v:IsA("BasePart") or v:IsA("Decal") then
                    OriginalTransparencies[v] = v.Transparency
                    v.Transparency = 1
                end
            end
            
            -- ลบ Nametag (ถ้ามี)
            if char:FindFirstChild("Head") and char.Head:FindFirstChild("nametag") then
                char.Head.nametag.Enabled = false -- ใช้ Enabled แทนการ Destroy เพื่อให้เอากลับมาได้
            end
            
            Fluent:Notify({ Title = "Invisible", Content = "เปิดโหมดล่องหนแล้ว", Duration = 3 })
        else
            -- เอากลับมาให้มองเห็นเหมือนเดิม
            for part, trans in pairs(OriginalTransparencies) do
                if part and part.Parent then
                    part.Transparency = trans
                end
            end
            
            -- เปิด Nametag กลับมา
            if char:FindFirstChild("Head") and char.Head:FindFirstChild("nametag") then
                char.Head.nametag.Enabled = true
            end
            
            OriginalTransparencies = {} -- ล้างค่าที่เก็บไว้
            Fluent:Notify({ Title = "Invisible", Content = "ปิดโหมดล่องหนแล้ว", Duration = 3 })
        end
    end
})

