	CurrentValue = false,
	Callback = function(v)
		AutoSell = v

		if AutoSell then
			-- สแกนใหม่ทุกครั้ง (กันเกมโหลดช้า)
			ScanSellRemotes()

			SellLoop = RunService.Heartbeat:Connect(function()
				for i = 1, 40 do
					FireSell()
				end
			end)
		else
			if SellLoop then
				SellLoop:Disconnect()
				SellLoop = nil
			end
		end
	end
})
