-- =========================
-- 🔥 AUTO SELL (UNIVERSAL + ไม่พัง)
-- =========================

local ReplicatedStorage = game:GetService("ReplicatedStorage")

local AutoSell = false
local SellLoop = nil
local SellRemotes = {}

-- 🔍 สแกนหา Remote อัตโนมัติ
local function ScanSellRemotes()
	SellRemotes = {}

	for _, v in ipairs(ReplicatedStorage:GetDescendants()) do
		if v:IsA("RemoteEvent") then
			local name = string.lower(v.Name)

			if string.find(name, "sell")
			or string.find(name, "cash")
			or string.find(name, "coin")
			or string.find(name, "reward")
			or string.find(name, "house") then
				
				table.insert(SellRemotes, v)
			end
		end
	end
end

ScanSellRemotes()

-- 🔥 ยิงทุกแบบ (กันเกมไม่เหมือนกัน)
local function FireSell()
	for _, remote in ipairs(SellRemotes) do
		pcall(function() remote:FireServer() end)
		pcall(function() remote:FireServer("Sell") end)
		pcall(function() remote:FireServer("sell") end)
		pcall(function() remote:FireServer(1) end)
	end
end

