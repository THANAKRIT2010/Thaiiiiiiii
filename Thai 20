--========================
-- AUTO TOOL
--========================
local running = false
local delay = 0.2

local currentTool
local cachedRemotes = {}
local cachedFunctions = {}

local function cacheRemotes(tool)
	cachedRemotes = {}
	cachedFunctions = {}
	if not tool then return end

	for _, d in ipairs(tool:GetDescendants()) do
		if d:IsA("RemoteEvent") then
			table.insert(cachedRemotes, d)
		elseif d:IsA("RemoteFunction") then
			table.insert(cachedFunctions, d)
		end
	end
end

local function fireMouseClick()
	pcall(function()
		VirtualUser:Button1Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
		task.wait(0.03)
		VirtualUser:Button1Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
	end)
end

local function autoLoop()
	while running do
		local char = player.Character
		local tool = char and char:FindFirstChildOfClass("Tool")

		if tool ~= currentTool then
			currentTool = tool
			cacheRemotes(tool)
		end

		if tool then
			pcall(function() tool:Activate() end)
			fireMouseClick()

			for _, re in ipairs(cachedRemotes) do
				pcall(function() re:FireServer() end)
			end

			for _, rf in ipairs(cachedFunctions) do
				pcall(function() rf:InvokeServer() end)
			end
		end

		task.wait(delay)
	end
end



--========================
-- ESP SYSTEM
--========================
local ESPEnabled = false
local ESP_Box = true
local ESP_Name = true
local ESP_Distance = true
local ESP_Line = true

local ESPObjects = {}

local function getRGB()
	local t = tick()
	return Color3.fromRGB(
		math.sin(t)*127+128,
		math.sin(t+2)*127+128,
		math.sin(t+4)*127+128
	)
end

local function CreateESP(plr)
	if plr == player then return end
	if ESPObjects[plr] then return end

	local esp = {}

	local highlight = Instance.new("Highlight")
	highlight.FillTransparency = 1
	highlight.Parent = game.CoreGui

	local billboard = Instance.new("BillboardGui")
	billboard.Size = UDim2.new(0,200,0,50)
	billboard.AlwaysOnTop = true

	local text = Instance.new("TextLabel")
	text.Size = UDim2.new(1,0,1,0)
	text.BackgroundTransparency = 1
	text.TextStrokeTransparency = 0
	text.TextScaled = true
	text.Parent = billboard

	billboard.Parent = game.CoreGui

	local line = Drawing.new("Line")
	line.Thickness = 1

	esp.Highlight = highlight
	esp.Billboard = billboard
	esp.Text = text
	esp.Line = line

	ESPObjects[plr] = esp
end

local function RemoveESP(plr)
	if ESPObjects[plr] then
		local esp = ESPObjects[plr]

		if esp.Highlight then esp.Highlight:Destroy() end
		if esp.Billboard then esp.Billboard:Destroy() end
		if esp.Line then esp.Line:Remove() end

		ESPObjects[plr] = nil
	end
end

RunService.RenderStepped:Connect(function()
	if not ESPEnabled then return end

	local char = player.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end

	local color = getRGB()

	for _, plr in pairs(Players:GetPlayers()) do
		if plr ~= player then

			if not ESPObjects[plr] then
				CreateESP(plr)
			end

			local esp = ESPObjects[plr]
			local char2 = plr.Character
			local hrp2 = char2 and char2:FindFirstChild("HumanoidRootPart")

			if char2 and hrp2 then
				local dist = (hrp.Position - hrp2.Position).Magnitude

				-- BOX
				if ESP_Box then
					esp.Highlight.Adornee = char2
					esp.Highlight.OutlineColor = color
					esp.Highlight.Enabled = true
				else
					esp.Highlight.Enabled = false
				end

				-- NAME + DIST
				if ESP_Name or ESP_Distance then
					esp.Billboard.Adornee = hrp2
					esp.Text.TextColor3 = color

					local txt = ""
					if ESP_Name then
						txt = plr.Name
					end
					if ESP_Distance then
						txt = txt .. " ["..math.floor(dist).."]"
					end

					esp.Text.Text = txt
					esp.Billboard.Enabled = true
				else
					esp.Billboard.Enabled = false
				end

				-- LINE
				if ESP_Line then
					local pos, vis = workspace.CurrentCamera:WorldToViewportPoint(hrp2.Position)

					if vis then
						esp.Line.From = Vector2.new(workspace.CurrentCamera.ViewportSize.X/2, workspace.CurrentCamera.ViewportSize.Y)
						esp.Line.To = Vector2.new(pos.X,pos.Y)
						esp.Line.Color = color
						esp.Line.Visible = true
					else
						esp.Line.Visible = false
					end
				else
					esp.Line.Visible = false
				end
			end
		end
	end
end)

Players.PlayerRemoving:Connect(RemoveESP)

