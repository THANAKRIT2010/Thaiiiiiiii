-- =========================
-- SMART LOOP
-- =========================
task.spawn(function()
	while true do
		if Follow and SelectedPlayer then

			local myChar = player.Character
			if not myChar then task.wait() continue end

			local humanoid = myChar:FindFirstChildOfClass("Humanoid")
			local myHRP = myChar:FindFirstChild("HumanoidRootPart")
			local targetHRP = GetHRP(SelectedPlayer)

			if humanoid and myHRP and targetHRP then

				local targetPos = targetHRP.Position

				-- PATHFINDING
				local path = PathfindingService:CreatePath({
					AgentRadius = 2,
					AgentHeight = 5,
					AgentCanJump = true
				})

				path:ComputeAsync(myHRP.Position, targetPos)

				if path.Status == Enum.PathStatus.Success then
					local waypoints = path:GetWaypoints()

					for _, wp in ipairs(waypoints) do
						if not Follow then break end

						humanoid:MoveTo(wp.Position)

						if wp.Action == Enum.PathWaypointAction.Jump then
							humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
						end

						task.wait(0.15)
					end

				else
					-- fallback เดินตรง
					humanoid:MoveTo(targetPos)

					-- ดึงแรงกันไม่ไป
					local dir = (targetPos - myHRP.Position)
					if dir.Magnitude > 5 then
						myHRP.AssemblyLinearVelocity = dir.Unit * 80
					end
				end
			end
		end

		task.wait(0.2)
	end
end)

