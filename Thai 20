-- =========================
-- FUNCTIONS
-- =========================
local function StopSit()
	if SitConnection then
		SitConnection:Disconnect()
		SitConnection = nil
	end
end

local function StartSit()
	if not SelectedPlayer then
		warn("ยังไม่ได้เลือกผู้เล่น")
		return
	end

	local myChar = player.Character or player.CharacterAdded:Wait()
	local myHRP = myChar:WaitForChild("HumanoidRootPart")
	local humanoid = myChar:WaitForChild("Humanoid")

	humanoid.Sit = true

	StopSit()

	SitConnection = RunService.RenderStepped:Connect(function()

		local targetChar = SelectedPlayer.Character
		local head = targetChar and targetChar:FindFirstChild("Head")
		if not head then return end

		-- 🔥 ล็อคหัวเป๊ะ
		myHRP.CFrame = head.CFrame * CFrame.new(0, 1.8, 0)

		-- 🔥 กันเด้ง
		myHRP.AssemblyLinearVelocity = Vector3.zero
		myHRP.AssemblyAngularVelocity = Vector3.zero

	end)
end

