-- 🎯 Target Mode Loop
local function startTargetMode()
    if targetModeConnection then return end
    
    targetModeConnection = RunService.Heartbeat:Connect(function()
        if not targetModeEnabled then return end
        
        local targetPlayer = findPlayerByName(targetPlayerName)
        if not targetPlayer then return end
        
        local targetChar = targetPlayer.Character
        if not targetChar or not targetChar:FindFirstChild("HumanoidRootPart") then return end
        
        local targetHum = targetChar:FindFirstChild("Humanoid")
        if not targetHum or targetHum.Health <= 0 then return end
        
        local character = LocalPlayer.Character
        if not character or not character:FindFirstChild("HumanoidRootPart") then return end
        
        local targetPos = targetChar.HumanoidRootPart.Position
        
        teleportAngle = teleportAngle + math.rad(fireRate * 3600)
        if teleportAngle > math.pi * 2 then
            teleportAngle = 0
        end
        
        teleportRadius = teleportRadius + (radiusDirection * 0.5)
        if teleportRadius >= 15 then
            radiusDirection = -1
        elseif teleportRadius <= 5 then
            radiusDirection = 1
        end
        
        local offsetX = math.cos(teleportAngle) * teleportRadius
        local offsetZ = math.sin(teleportAngle) * teleportRadius
        local newPos = Vector3.new(targetPos.X + offsetX, targetPos.Y, targetPos.Z + offsetZ)
        
        character.HumanoidRootPart.CFrame = CFrame.new(newPos, targetPos)
        
        local currentTime = tick()
        
        if burstModeEnabled then
            -- 🔴 โหมดยิงทีเดียว
            local gun = character:FindFirstChild("Gun")
            if not gun then
                equipGun()
                return
            end
            
            local shootPos = getPredictedPosition(targetChar)
            
            if gun:FindFirstChild("shot") then
                local args = { [1] = shootPos }
                gun.shot:FireServer(unpack(args))
                
                if #getAllGuns() > 1 then
                    wait(0.001)
                    switchGun()
                end
            end
        else
            -- 🔵 โหมดยิงเลื่อยๆ
            if currentTime - lastShotTime < fireRate then
                return
            end
            
            local gun = character:FindFirstChild("Gun")
            if not gun then
                equipGun()
                return
            end
            
            local shootPos = getPredictedPosition(targetChar)
            
            if gun:FindFirstChild("shot") then
                local args = { [1] = shootPos }
                gun.shot:FireServer(unpack(args))
                lastShotTime = currentTime
                
                if #getAllGuns() > 1 then
                    task.spawn(function()
                        wait(0.01)
                        switchGun()
                    end)
                end
            end
        end
    end)
end

local function stopTargetMode()
    if targetModeConnection then
        targetModeConnection:Disconnect()
        targetModeConnection = nil
    end
    stopAntiSeat()
    teleportAngle = 0
    teleportRadius = 10
    radiusDirection = 1
    lastShotTime = 0
end

