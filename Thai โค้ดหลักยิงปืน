-- 🎯 Calculate Predicted Position
local function getPredictedPosition(targetChar)
    if not predictionEnabled then
        return targetChar.HumanoidRootPart.Position
    end
    
    local targetRoot = targetChar.HumanoidRootPart
    local currentPos = targetRoot.Position
    local velocity = targetRoot.AssemblyLinearVelocity
    
    local predictionTime = fireRate * 2
    local predictedPos = currentPos + (velocity * predictionTime)
    
    return predictedPos
end

-- 🎯 Get Closest Player with Line of Sight
local function getClosestPlayer()
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then
        return nil
    end
    
    local myPos = character.HumanoidRootPart.Position
    local myHead = character:FindFirstChild("Head")
    if not myHead then return nil end
    
    local closestPlayer = nil
    local shortestDistance = math.huge
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local targetChar = player.Character
            if targetChar and targetChar:FindFirstChild("HumanoidRootPart") then
                local targetHum = targetChar:FindFirstChild("Humanoid")
                
                if targetHum and targetHum.Health > 0 then
                    local targetPos = targetChar.HumanoidRootPart.Position
                    local targetHead = targetChar:FindFirstChild("Head")
                    
                    if targetHead then
                        local distance = (myPos - targetPos).Magnitude
                        
                        local rayOrigin = myHead.Position
                        local rayDirection = (targetHead.Position - rayOrigin).Unit * distance
                        
                        local raycastParams = RaycastParams.new()
                        raycastParams.FilterDescendantsInstances = {character, targetChar}
                        raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
                        raycastParams.IgnoreWater = true
                        
                        local rayResult = workspace:Raycast(rayOrigin, rayDirection, raycastParams)
                        
                        if not rayResult or rayResult.Instance:IsDescendantOf(targetChar) then
                            if distance < shortestDistance then
                                shortestDistance = distance
                                closestPlayer = player
                            end
                        end
                    end
                end
            end
        end
    end
    
    return closestPlayer
end

-- 💥 Kill Aura Loop
local killAuraConnection = nil
local targetModeConnection = nil
local antiSeatConnection = nil
local lastShotTime = 0

local function startKillAura()
    if killAuraConnection then return end
    
    killAuraConnection = RunService.Heartbeat:Connect(function()
        if not killAuraEnabled then return end
        
        local currentTime = tick()
        
        if burstModeEnabled then
            -- 🔴 โหมดยิงทีเดียว - สลับปืนเร็วมาก
            local target = getClosestPlayer()
            if not target then return end
            
            local targetChar = target.Character
            if not targetChar or not targetChar:FindFirstChild("HumanoidRootPart") then return end
            
            local targetHum = targetChar:FindFirstChild("Humanoid")
            if not targetHum or targetHum.Health <= 0 then return end
            
            local gun = LocalPlayer.Character:FindFirstChild("Gun")
            if not gun then
                equipGun()
                return
            end
            
            local shootPos = getPredictedPosition(targetChar)
            
            if gun:FindFirstChild("shot") then
                local args = { [1] = shootPos }
                gun.shot:FireServer(unpack(args))
                
                -- 🔄 สลับปืนทันที (0.001s)
                if #getAllGuns() > 1 then
                    wait(0.001)
                    switchGun()
                end
            end
        else
            -- 🔵 โหมดยิงเลื่อยๆ - ปกติ
            if currentTime - lastShotTime < fireRate then
                return
            end
            
            local target = getClosestPlayer()
            if not target then return end
            
            local targetChar = target.Character
            if not targetChar or not targetChar:FindFirstChild("HumanoidRootPart") then return end
            
            local targetHum = targetChar:FindFirstChild("Humanoid")
            if not targetHum or targetHum.Health <= 0 then return end
            
            local gun = LocalPlayer.Character:FindFirstChild("Gun")
            if not gun then
                equipGun()
                return
            end
            
            local shootPos = getPredictedPosition(targetChar)
            
            if gun:FindFirstChild("shot") then
                local args = { [1] = shootPos }
                gun.shot:FireServer(unpack(args))
                lastShotTime = currentTime
                
                if #getAllGuns() > 1 then
                    task.spawn(function()
                        wait(0.01)
                        switchGun()
                    end)
                end
            end
        end
    end)
end

local function stopKillAura()
    if killAuraConnection then
        killAuraConnection:Disconnect()
        killAuraConnection = nil
    end
    lastShotTime = 0
end

