-- 🔍 Find Player by Partial Name
local function findPlayerByName(partialName)
    if partialName == "" then return nil end
    
    local lowerPartial = partialName:lower()
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local lowerName = player.Name:lower()
            local lowerDisplay = player.DisplayName:lower()
            
            if lowerName:find(lowerPartial, 1, true) or lowerDisplay:find(lowerPartial, 1, true) then
                return player
            end
        end
    end
    
    return nil
end

-- 🔫 Get All Guns from Backpack
local function getAllGuns()
    local guns = {}
    for _, tool in pairs(LocalPlayer.Backpack:GetChildren()) do
        if tool:IsA("Tool") and tool.Name == "Gun" then
            table.insert(guns, tool)
        end
    end
    return guns
end

-- 🔄 Switch Gun (Invisible Mode)
local function switchGun()
    local guns = getAllGuns()
    
    if #guns == 0 then
        return false
    end
    
    if LocalPlayer.Character then
        local equippedGun = LocalPlayer.Character:FindFirstChild("Gun")
        if equippedGun then
            equippedGun.Parent = LocalPlayer.Backpack
        end
    end
    
    if currentGunIndex > #guns then
        currentGunIndex = 1
    end
    
    local selectedGun = guns[currentGunIndex]
    
    if selectedGun and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
